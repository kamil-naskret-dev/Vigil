# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (use 'localhost' for local dev, 'postgres' inside Docker)
POSTGRES_USER=vigil
POSTGRES_PASSWORD=vigil
POSTGRES_DB=vigil
POSTGRES_PORT=5432
DATABASE_URL="postgresql://vigil:vigil@localhost:5432/vigil"

# Redis (use 'localhost' for local dev, 'redis' inside Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_in_production
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (email alerts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Vigil <alerts@example.com>"
